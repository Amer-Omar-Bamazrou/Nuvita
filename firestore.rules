rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper — true if the requester has a document in /doctors
    function isDoctor() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/doctors/$(request.auth.uid));
    }

    // Users can access their own data; doctors can read/write any patient
    match /users/{userId} {
      allow read, write: if request.auth != null
        && (request.auth.uid == userId || isDoctor());

      match /readings/{readingId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isDoctor());
      }

      match /alerts/{alertId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isDoctor());
      }

      match /medications/{medicationId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isDoctor());
      }

      match /profile/{document=**} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isDoctor());
      }

      match /suggestions/{suggestionId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isDoctor());
      }

      match /messages/{msgId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == userId || isDoctor());
      }
    }

    // Collection group queries for doctor read access
    match /{path=**}/readings/{readingId} {
      allow read: if isDoctor();
    }

    match /{path=**}/suggestions/{suggestionId} {
      allow read: if isDoctor();
    }

    match /{path=**}/alerts/{alertId} {
      allow read: if isDoctor();
    }

    match /{path=**}/messages/{msgId} {
      allow read, write: if isDoctor();
    }

    // Doctors collection — only the doctor themselves can read their own doc
    match /doctors/{doctorId} {
      allow read: if request.auth != null && request.auth.uid == doctorId;
      allow write: if false; // admin-only via Firebase Console
    }

    // Share tokens — anyone can read, auth users can write
    match /share_tokens/{tokenId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
