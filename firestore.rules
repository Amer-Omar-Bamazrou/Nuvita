rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;

      // Health readings sub-collection
      match /readings/{readingId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      // Emergency alerts sub-collection
      match /alerts/{alertId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      // Medications sub-collection
      match /medications/{medicationId} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }

      // Profile documents (wildcard covers nested paths)
      match /profile/{document=**} {
        allow read, write: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // Share tokens — anyone can read a token link, only auth users can write
    match /share_tokens/{tokenId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}